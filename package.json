{
  "name": "projekt",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "clean:dist": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path 'dist') { Remove-Item -LiteralPath 'dist' -Recurse -Force }\"",
    "build": "vite build",
    "build:gh": "npm run clean:dist && vite build --base=./ && node -e \"require('node:fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "preview": "vite preview",
    "preview:gh": "vite preview",
    "deploy": "npm run build:gh && gh-pages -r https://github.com/zoltanfa/Zaverecna_praca_Vue.js.git -d dist && npm run clean:dist"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "gh-pages": "^6.3.0",
    "vite": "^7.3.0",
    "vite-plugin-vue-devtools": "^8.0.5"
  }
}
